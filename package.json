{
  "name": "nothingclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "nothingclaw": "./src/cli/index.ts"
  },
  "scripts": {
    "setup": "bun run src/cli/index.ts setup",
    "start": "bun run src/cli/index.ts start",
    "status": "bun run src/cli/index.ts status",
    "provider": "bun run src/cli/index.ts provider",
    "whatsapp": "bun run src/cli/index.ts whatsapp",
    "voice": "bun run src/cli/index.ts voice",
    "google": "bun run src/cli/index.ts google",
    "service": "bun run src/cli/index.ts service",
    "path": "bun run src/cli/index.ts path",
    "backup": "bun run src/cli/index.ts backup",
    "db": "bun run src/cli/index.ts db",
    "usage": "bun run src/cli/index.ts usage",
    "update": "bun run src/cli/index.ts update",
    "smoke": "bun run src/cli/index.ts smoke",
    "dev": "bun run src/cli/index.ts start",
    "mcp": "bun run src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "LOG_LEVEL=error bun test tests",
    "test:watch": "LOG_LEVEL=error bun test --watch tests",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@slack/bolt": "^3.22.0",
    "baileys": "7.0.0-rc13",
    "googleapis": "^172.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "pino": "^9.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "latest",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.15.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0"
  }
}
