;; marsClaw macOS sandbox profile — deny-default.
;;
;; sandbox-exec is the legacy interface to the macOS Sandbox (TrustedBSD-MAC).
;; Undocumented and deprecated by Apple, but still functional and the only way
;; to get kernel-enforced containment without a System Extension.
;;
;; This profile is DENY-DEFAULT: anything not explicitly allowed is refused by
;; the kernel. That's stricter than the previous (allow default) stub — but a
;; Bun+Node process touches many operation classes, so EXPECT to add allows on
;; first runs. How to iterate:
;;   1. Run the bot under this profile (tools/sandbox/run-macos.sh).
;;   2. Watch Console.app (or `log stream --predicate 'sender == "Sandbox"'`)
;;      for "deny" lines naming the operation + target.
;;   3. Add a matching (allow …) below, restart, repeat until it boots clean.
;;
;; The real protections here are WRITE confinement, network containment (the
;; optional loopback-only block), and denies of pivot paths the bot never needs
;; (SSH keys, cookies). NOTE: the bot's own credentials (.env, ~/.claude.json,
;; data/whatsapp-auth, Keychain) are intentionally NOT denied — the bot reads
;; them to function, and denying .env makes Bun abort at launch. Kernel-denying
;; those needs identity separation (container) or the credential-isolation
;; layer. See the DENIES section at the bottom for the full rationale.
;;
;; Usage: sandbox-exec -f marsclaw.sb -D PROJECT=$PWD -D HOME=$HOME bun run src/cli/index.ts start

(version 1)
(deny default)

;; Allow the kernel to tell us WHY something was denied (shows targets in logs).
(allow file-read-metadata)

;; --- Process / exec --------------------------------------------------------
(allow process-fork)
(allow process-exec)
(allow signal (target self))

;; --- Filesystem reads ------------------------------------------------------
;; Broad read. A SCOPED read list is a trap here: the dynamic linker (dyld)
;; maps the shared cache + system dylibs from paths that are easy to miss, and
;; a missing read makes dyld abort() the process at launch (SIGABRT, no error
;; on stderr — the denial only shows in the unified log). So we allow reads
;; broadly and carve out the credentials at the BOTTOM (last-match-wins),
;; which is the part that actually matters for the prompt-injection threat.
(allow file-read*)

;; --- Filesystem writes (tight) ---------------------------------------------
;; Only the bot's own writable surface + temp + std devices.
(allow file-write*
  (subpath (string-append (param "PROJECT") "/data"))
  (subpath (string-append (param "PROJECT") "/logs"))
  (subpath (string-append (param "PROJECT") "/wiki"))
  (literal (string-append (param "PROJECT") "/MEMORY.md"))
  (subpath "/private/var/folders")
  (subpath "/private/tmp")
  (subpath "/tmp")
  (literal "/dev/null")
  (literal "/dev/dtracehelper"))

;; --- Network ---------------------------------------------------------------
;; Default: allow outbound (the bot must reach Telegram/Anthropic/etc.). When
;; you've installed the pf anchor and set MARSCLAW_EGRESS_ENFORCED=1, you can
;; tighten this to loopback-only (forcing everything through the local gateway)
;; by commenting the broad allow and uncommenting the loopback block.
(allow network*)
;; (allow network-outbound (remote ip "127.0.0.1:*") (remote ip "localhost:*") (remote ip "::1:*"))
;; (allow network-outbound (remote unix-socket))
;; (allow network-bind (local ip "127.0.0.1:*"))

;; --- Mach / IOKit / sysctl (generous; tightening these is a later pass) ----
(allow mach-lookup)
(allow iokit-open)
(allow sysctl-read)
(allow ipc-posix-shm)

;; ===========================================================================
;; DENIES — last-match-wins, so these override the broad reads above.
;;
;; IMPORTANT — what this sandbox can and cannot protect, and WHY:
;;
;; The agent runs INSIDE the bot's own process. So any credential the BOT needs
;; to function, the agent's process can necessarily reach — you cannot kernel-
;; deny the bot its own secrets without breaking the bot. Concretely, these are
;; NOT denied because the bot legitimately reads them at startup/runtime:
;;   - .env            → Bun auto-loads it for config (MARSCLAW_*, OAuth client
;;                        id/secret). Denying it makes Bun ABORT at launch
;;                        (EPERM, not ENOENT) — the bot can't even start.
;;   - ~/.claude.json, ~/.gemini → the agent SDK reads these for auth.
;;   - data/whatsapp-auth        → Baileys reads/writes its session here.
;;   - ~/Library/Keychains       → Google OAuth tokens (via securityd).
;; To kernel-deny THOSE you need identity separation (the agent running as a
;; different user / in a container), or the full credential-isolation layer
;; (LLM proxy + .env-via-env + Google-auth-via-broker). See docs/security.md.
;;
;; What this sandbox DOES still buy you, even with the bot's creds readable:
;;   - write confinement (a hijacked shell can only write data/, logs/, tmp)
;;   - network containment (uncomment the loopback-only block above once the
;;     egress gateway is enforced)
;;   - denies pivot targets the bot never touches (SSH keys, browser cookies)
;;   - the OS-level process/exec/mach baseline of deny-default
;;
;; So we deny only paths the bot has no legitimate need for:
;; ===========================================================================
(deny file-read* file-write*
  (subpath (string-append (param "HOME") "/.ssh")))
(deny file-read* file-write*
  (subpath (string-append (param "HOME") "/Library/Cookies")))
(deny file-read* file-write*
  (subpath (string-append (param "PROJECT") "/data/secrets")))  ;; Linux-only creds; empty on macOS
